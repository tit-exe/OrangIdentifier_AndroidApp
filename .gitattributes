# Git LFS — large binary files tracked separately
# Le backbone (112 MB) dépasse la limite GitHub de 100 MB → stocké via LFS.
app/src/main/assets/megadesc_v6_backbone.tflite filter=lfs diff=lfs merge=lfs -text

# Les autres binaires volumineux éventuels
*.apk filter=lfs diff=lfs merge=lfs -text
*.aab filter=lfs diff=lfs merge=lfs -text
