<?xml version="1.0" encoding="utf-8"?>
<!-- Root FrameLayout so we can layer the batch-loading overlay on top -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── Main content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/surface_secondary">

        <!-- Annotated image -->
        <ImageView
            android:id="@+id/iv_result"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:background="@color/black" />

        <!-- Summary line -->
        <TextView
            android:id="@+id/tv_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:background="@color/surface_primary" />

        <TextView
            android:id="@+id/tv_timestamp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:background="@color/surface_primary" />

        <!-- Per-face detection cards -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3">

            <LinearLayout
                android:id="@+id/container_faces"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp" />

        </ScrollView>

        <!-- Batch navigation bar — GONE when no active batch -->
        <LinearLayout
            android:id="@+id/batch_nav_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp"
            android:background="@color/surface_primary"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_batch_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <Button
                android:id="@+id/btn_next_scan"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Next →"
                android:textSize="13sp"
                android:backgroundTint="@color/green_600" />

        </LinearLayout>

        <!-- Bottom action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp">

            <Button
                android:id="@+id/btn_new_scan"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/btn_new_scan"
                android:backgroundTint="@color/green_600"
                android:layout_marginEnd="8dp" />

            <Button
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:id="@+id/btn_edit_boxes"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Edit boxes" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Batch loading overlay — shown while waiting for next result ── -->
    <LinearLayout
        android:id="@+id/batch_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/green_600" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Processing next image…"
            android:textSize="15sp"
            android:textColor="@color/white" />

    </LinearLayout>

</FrameLayout>
